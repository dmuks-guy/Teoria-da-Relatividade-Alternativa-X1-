# Matéria como Evento Quântico em Expansão Macro
# =====================================================

import numpy as np
from numba import cuda
import math
import matplotlib.pyplot as plt
import time

# 1. Configuração de Escala (16.8 Milhões de Pontos)
Nx, Ny, Nz = 256, 256, 256
dx = dy = dz = 0.5

print(f"Iniciando Teoria X1: {Nx*Ny*Nz} pontos de grade...")

# Alocação de Memória na GPU
X_gpu = cuda.device_array((Nx, Ny, Nz), dtype=np.float32)
U_gpu = cuda.device_array((Nx, Ny, Nz, 4), dtype=np.float32)
T_gpu = cuda.device_array((Nx, Ny, Nz, 4), dtype=np.float32)
Psi_gpu = cuda.device_array((Nx, Ny, Nz), dtype=np.float32)
step_gpu = cuda.device_array(1, dtype=np.int32)

# 2. Kernel de Processamento Unificado (X1-Massive)
@cuda.jit
def x1_kernel_massive(X, U, T, Psi, step):
    i, j, k = cuda.grid(3)
    Nx, Ny, Nz = X.shape

    if i >= Nx or j >= Ny or k >= Nz:
        return

    # Dinâmica de Campo Escalar (Oceano Quântico)
    r2 = (i-Nx/2)**2 + (j-Ny/2)**2 + (k-Nz/2)**2
    sigma_bg = 32.0 + 0.05 * step[0]
    sigma_gal = 4.0

    # Evolução do Campo X
    X[i,j,k] = (math.exp(-r2/(2*sigma_bg*sigma_bg)) +
                3.0*math.exp(-(r2/8 + math.sin(i*0.1)*math.sin(j*0.1))/(2*sigma_gal*sigma_gal)))

    # Tensores e Gradientes (Relatividade)
    dX_t = 1.0 + 0.02 * step[0]
    dX_x = 0.5*(X[i+1,j,k] - X[i-1,j,k]) if 1<=i<=Nx-2 else 0.0
    dX_y = 0.5*(X[i,j+1,k] - X[i,j-1,k]) if 1<=j<=Ny-2 else 0.0
    dX_z = 0.5*(X[i,j,k+1] - X[i,j,k-1]) if 1<=k<=Nz-2 else 0.0

    grad2 = dX_t*dX_t - dX_x*dX_x - dX_y*dX_y - dX_z*dX_z

    # Normalização da Quadrivelocidade U
    if grad2 > 1e-8:
        norm = math.sqrt(abs(grad2))
        U[i,j,k,0] = dX_t / norm
        U[i,j,k,1] = dX_x / norm * 0.3
        U[i,j,k,2] = dX_y / norm * 0.3
        U[i,j,k,3] = dX_z / norm * 0.3
    else:
        U[i,j,k,0] = 1.0
        U[i,j,k,1] = 0.0
        U[i,j,k,2] = 0.0
        U[i,j,k,3] = 0.0

    # Energia e Pressão (Cosmologia)
    Vx = 0.08*X[i,j,k]*X[i,j,k] - 0.03*step[0]*X[i,j,k]
    rho = 0.5*grad2 + Vx
    w_cosmo = -0.5 - 0.01*step[0]
    p = rho * max(w_cosmo, -0.999)

    T[i,j,k,0] = rho
    T[i,j,k,1] = p
    T[i,j,k,2] = U[i,j,k,0]*dX_x
    T[i,j,k,3] = U[i,j,k,0]*dX_y

    # Manifestação da Matéria (Psi): Evento Quântico Discreto
    epsilon = 0.08
    interaction = abs(U[i,j,k,0]*dX_t + 0.5*(abs(dX_x)+abs(dX_y)+abs(dX_z)))
    collapse = 1.0 if interaction > epsilon else 0.0
    Psi[i,j,k] = collapse * X[i,j,k]

# 3. Configuração de Hardware GPU
threadsperblock = (16, 16, 4)
blockspergrid_x = math.ceil(Nx / threadsperblock[0])
blockspergrid_y = math.ceil(Ny / threadsperblock[1])
blockspergrid_z = math.ceil(Nz / threadsperblock[2])
blockspergrid = (blockspergrid_x, blockspergrid_y, blockspergrid_z)

# 4. Loop de Evolução Temporal
step_cpu = 0
try:
    while True:
        step_cpu += 1
        step_array = np.array([step_cpu], dtype=np.int32)
        step_gpu.copy_to_device(step_array)

        # Execução Massiva na GPU
        x1_kernel_massive[blockspergrid, threadsperblock](
            X_gpu, U_gpu, T_gpu, Psi_gpu, step_gpu
        )

        # Amostragem para Monitoramento (Slices para não travar o Host)
        U_sample = U_gpu[::4, ::4, ::4].copy_to_host()
        T_sample = T_gpu[::4, ::4, ::4].copy_to_host()
        Psi_sample = Psi_gpu[::4, ::4, ::4].copy_to_host()

        rho_mean = np.mean(T_sample[...,0])
        p_mean = np.mean(T_sample[...,1])
        w_de = p_mean / rho_mean if rho_mean > 0 else 0
        n_collapses = np.sum(Psi_sample > 0.1)

        print(f"Passo {step_cpu} | Rho: {rho_mean:.4f} | w: {w_de:.3f} | Eventos Psi: {n_collapses}")

        # Visualização Gráfica em Tempo Real
        fig, (ax1, ax2, ax3) = plt.subplots(1, 3, figsize=(15, 5))
        
        im1 = ax1.imshow(U_gpu[::8, Ny//2, ::8, 0].copy_to_host(), cmap='viridis')
        ax1.set_title('U^t (Tempo)')
        
        im2 = ax2.imshow(T_gpu[Nx//2, ::8, ::8, 0].copy_to_host(), cmap='plasma')
        ax2.set_title('Densidade (Rho)')
        
        im3 = ax3.imshow(Psi_gpu[::8, Ny//2, ::8].copy_to_host(), cmap='coolwarm')
        ax3.set_title('Eventos Matéria (Psi)')

        plt.suptitle(f'Teoria X1 - Simulação Cosmogônica Passo {step_cpu}')
        plt.tight_layout()
        plt.pause(0.1)
        plt.close()

except KeyboardInterrupt:
    print("\nSimulação Finalizada pelo Usuário.")
    print(f"Total de pontos simulados: {Nx*Ny*Nz}")

